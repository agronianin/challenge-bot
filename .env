# Telegram bot
BOT_TOKEN=replace_me
BOT_USERNAME=challenge_bot
CHAT_ID=replace_me

# Database (JDBC)
DB_NAME=challenge
DB_USER=challenge
DB_PASSWORD=challenge
DATABASE_URL=jdbc:postgresql://postgres:5432/challenge

# Scheduling
TIMEZONE=Europe/Moscow
POST_TIME=08:00

# Program defaults
EXERCISES_PER_DAY=3
GROUPS_PER_DAY=2

# Reps growth
REPS_GROWTH_PERCENT=0.05
REPS_ROUND_MODE=ceil

# Logging
LOG_LEVEL=INFO
